# Pull specific ubuntu 22.04 image
FROM ubuntu@sha256:728785b59223d755e3e5c5af178fab1be7031f3522c5ccd7a0b32b80d8248123


# Path of nri-flex
ARG flex_bin

# Path of the binary tests
