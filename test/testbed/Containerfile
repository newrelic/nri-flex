# Pull specific ubuntu 22.04 image
FROM ubuntu@sha256:353675e2a41babd526e2b837d7ec780c2a05bca0164f7ea5dbbd433d21d166fc


# Path of nri-flex
ARG flex_bin

# Path of the binary tests
ARG flex_tests_bin

# Add the nri-flex binary
COPY $flex_bin /bin/nri-flex
